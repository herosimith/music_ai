{
  "$defs": {
    "CorrectionType": {
      "enum": [
        "sharp",
        "flat",
        "octave_error",
        "early",
        "late",
        "short",
        "long",
        "missed",
        "unstable"
      ],
      "title": "CorrectionType",
      "type": "string"
    },
    "EvidencePointer": {
      "additionalProperties": false,
      "properties": {
        "artifact_id": {
          "maxLength": 256,
          "minLength": 1,
          "title": "Artifact Id",
          "type": "string"
        },
        "end_sample": {
          "exclusiveMinimum": 0,
          "title": "End Sample",
          "type": "integer"
        },
        "start_sample": {
          "minimum": 0,
          "title": "Start Sample",
          "type": "integer"
        }
      },
      "required": [
        "artifact_id",
        "start_sample",
        "end_sample"
      ],
      "title": "EvidencePointer",
      "type": "object"
    },
    "NumericMetric": {
      "additionalProperties": false,
      "properties": {
        "confidence": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Confidence",
          "type": "number"
        },
        "coverage": {
          "maximum": 1.0,
          "minimum": 0.0,
          "title": "Coverage",
          "type": "number"
        },
        "unit": {
          "enum": [
            "cents",
            "milliseconds",
            "ratio",
            "hertz",
            "semitones"
          ],
          "title": "Unit",
          "type": "string"
        },
        "value": {
          "title": "Value",
          "type": "number"
        }
      },
      "required": [
        "value",
        "unit",
        "confidence",
        "coverage"
      ],
      "title": "NumericMetric",
      "type": "object"
    }
  },
  "additionalProperties": false,
  "properties": {
    "confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Confidence",
      "type": "number"
    },
    "correction_id": {
      "format": "uuid",
      "title": "Correction Id",
      "type": "string"
    },
    "correction_type": {
      "$ref": "#/$defs/CorrectionType"
    },
    "end_sample": {
      "exclusiveMinimum": 0,
      "title": "End Sample",
      "type": "integer"
    },
    "evidence": {
      "items": {
        "$ref": "#/$defs/EvidencePointer"
      },
      "maxItems": 20,
      "minItems": 1,
      "title": "Evidence",
      "type": "array"
    },
    "observed": {
      "anyOf": [
        {
          "$ref": "#/$defs/NumericMetric"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "phrase_id": {
      "format": "uuid",
      "title": "Phrase Id",
      "type": "string"
    },
    "produced_at": {
      "format": "date-time",
      "title": "Produced At",
      "type": "string"
    },
    "reference": {
      "anyOf": [
        {
          "$ref": "#/$defs/NumericMetric"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "reference_confidence": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Reference Confidence",
      "type": "number"
    },
    "schema_version": {
      "const": "correction-event.v1",
      "title": "Schema Version",
      "type": "string"
    },
    "score_version": {
      "maxLength": 128,
      "minLength": 1,
      "title": "Score Version",
      "type": "string"
    },
    "session_id": {
      "format": "uuid",
      "title": "Session Id",
      "type": "string"
    },
    "severity": {
      "maximum": 1.0,
      "minimum": 0.0,
      "title": "Severity",
      "type": "number"
    },
    "start_sample": {
      "minimum": 0,
      "title": "Start Sample",
      "type": "integer"
    },
    "tenant_id": {
      "format": "uuid",
      "title": "Tenant Id",
      "type": "string"
    }
  },
  "required": [
    "schema_version",
    "tenant_id",
    "session_id",
    "phrase_id",
    "correction_id",
    "correction_type",
    "start_sample",
    "end_sample",
    "severity",
    "confidence",
    "reference_confidence",
    "evidence",
    "score_version",
    "produced_at"
  ],
  "title": "CorrectionEventV1",
  "type": "object"
}
