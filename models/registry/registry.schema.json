{
  "$defs": {
    "ModelRecord": {
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "commercial_use_approved": {
                "const": true
              }
            },
            "required": [
              "commercial_use_approved"
            ]
          },
          "then": {
            "properties": {
              "training_data_review": {
                "const": "approved"
              }
            }
          }
        }
      ],
      "properties": {
        "approved_at": {
          "format": "date-time",
          "title": "Approved At",
          "type": "string"
        },
        "approved_by": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Approved By",
          "type": "string"
        },
        "artifact_sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Artifact Sha256",
          "type": "string"
        },
        "code_license_spdx": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Code License Spdx",
          "type": "string"
        },
        "commercial_use_approved": {
          "title": "Commercial Use Approved",
          "type": "boolean"
        },
        "constraints": {
          "items": {
            "maxLength": 500,
            "minLength": 1,
            "type": "string"
          },
          "maxItems": 100,
          "title": "Constraints",
          "type": "array"
        },
        "model_id": {
          "maxLength": 128,
          "minLength": 2,
          "pattern": "^[a-z0-9][a-z0-9._-]+$",
          "title": "Model Id",
          "type": "string"
        },
        "source_url": {
          "format": "uri",
          "minLength": 1,
          "title": "Source Url",
          "type": "string"
        },
        "task": {
          "$ref": "#/$defs/ModelTask"
        },
        "training_data_review": {
          "$ref": "#/$defs/TrainingDataReview"
        },
        "weight_license_spdx": {
          "maxLength": 200,
          "minLength": 1,
          "title": "Weight License Spdx",
          "type": "string"
        }
      },
      "required": [
        "model_id",
        "task",
        "artifact_sha256",
        "source_url",
        "code_license_spdx",
        "weight_license_spdx",
        "training_data_review",
        "commercial_use_approved",
        "approved_by",
        "approved_at"
      ],
      "title": "ModelRecord",
      "type": "object"
    },
    "ModelTask": {
      "enum": [
        "source_separation",
        "f0",
        "alignment",
        "vad",
        "quality_gate"
      ],
      "title": "ModelTask",
      "type": "string"
    },
    "TrainingDataReview": {
      "enum": [
        "pending",
        "approved",
        "rejected"
      ],
      "title": "TrainingDataReview",
      "type": "string"
    }
  },
  "additionalProperties": false,
  "properties": {
    "models": {
      "items": {
        "$ref": "#/$defs/ModelRecord"
      },
      "maxItems": 1000,
      "title": "Models",
      "type": "array"
    },
    "schema_version": {
      "const": "model-registry.v1",
      "title": "Schema Version",
      "type": "string"
    }
  },
  "required": [
    "schema_version"
  ],
  "title": "ModelRegistryV1",
  "type": "object"
}
