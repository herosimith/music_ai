MUSIC_AI_ENVIRONMENT=development
MUSIC_AI_DATABASE_URL=sqlite:///./.local/control-plane.db
MUSIC_AI_OBJECT_STORE_ROOT=.local/object-store
MUSIC_AI_TOKEN_PEPPER=replace-with-a-random-secret-at-least-32-chars
MUSIC_AI_RAW_AUDIO_TTL_SECONDS=900
MUSIC_AI_MAINTENANCE_INTERVAL_SECONDS=300
MUSIC_AI_AUTO_CREATE_SCHEMA=true
MUSIC_AI_BOOTSTRAP_TENANT_SLUG=local-dev
MUSIC_AI_BOOTSTRAP_TENANT_NAME=Local Development
MUSIC_AI_BOOTSTRAP_API_TOKEN=replace-with-a-random-token-at-least-32-chars
MUSIC_AI_COACH_BASE_URL=https://api.openai.com/v1
MUSIC_AI_COACH_MODEL=gpt-5.6-luna
MUSIC_AI_COACH_API_KEY=replace-with-a-provider-api-key
